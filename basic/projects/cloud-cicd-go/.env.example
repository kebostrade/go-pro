# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_BUCKET_NAME=your-bucket-name
GCP_PUBSUB_TOPIC=your-topic
GCP_FIRESTORE_COLLECTION=users
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Amazon Web Services
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=your-s3-bucket
AWS_DYNAMODB_TABLE=users
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/your-queue
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:your-topic

# Application
PORT=8080
ENV=development
LOG_LEVEL=info

# Docker
DOCKER_REGISTRY=gcr.io
DOCKER_IMAGE_NAME=cloud-cicd-app
DOCKER_TAG=latest

# Kubernetes
K8S_NAMESPACE=default
K8S_DEPLOYMENT_NAME=cloud-app
K8S_SERVICE_NAME=cloud-app-service

