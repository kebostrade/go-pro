# Docker Compose Environment Variables
# Copy this file to .env and set secure passwords

# PostgreSQL
POSTGRES_USER=devops_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN

# Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_16_CHARS_MIN

# Generate strong passwords with:
# openssl rand -base64 32
