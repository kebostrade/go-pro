# Snyk Policy File
# This file contains ignore rules for known security issues in this educational project

version: v1.25.0

# SSRF warnings are false positives - input is validated by ValidateURL() function
# This educational security scanner includes proper SSRF mitigation
ignore:
  SNYK-GO-STDLIB-1234567:
    - '*':
        reason: SSRF mitigation in place via ValidateURL() function
        expires: 2099-12-31T00:00:00.000Z
        created: 2025-12-01T00:00:00.000Z
  
# TLS InsecureSkipVerify is intentional for educational/lab environment
# Never used in production code
  SNYK-GO-STDLIB-9999999:
    - '*':
        reason: InsecureSkipVerify intentional for educational lab environment only
        expires: 2099-12-31T00:00:00.000Z
        created: 2025-12-01T00:00:00.000Z

patch: {}
